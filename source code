<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kalkulačka COGS pro 3D tisk</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Inter', sans-serif;
        }
        input[type="number"]::-webkit-inner-spin-button,
        input[type="number"]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type="number"] {
            -moz-appearance: textfield;
        }
        .profit-box-positive {
            background-color: #d1fae5; /* green-50 */
            border-color: #6ee7b7;   /* green-300 */
        }
        .profit-box-negative {
            background-color: #fee2e2; /* red-50 */
            border-color: #fca5a5;   /* red-300 */
        }
    </style>
</head>
<body class="bg-gray-100 text-gray-800 p-4 sm:p-8">

    <div class="max-w-7xl mx-auto bg-white p-6 sm:p-8 rounded-2xl shadow-xl border border-gray-200">
        <h1 class="text-3xl sm:text-4xl font-extrabold text-center text-blue-800 mb-6 sm:mb-8">Kalkulačka COGS pro 3D tisk</h1>
        <p class="text-center text-gray-600 mb-4">
            Zadejte níže své náklady a automaticky vypočítejte náklady na prodané zboží (COGS) pro své 3D tištěné produkty.
        </p>

        <!-- Product Name Input -->
        <div class="mb-8">
            <label for="productName" class="block text-sm font-semibold text-gray-700 mb-2">Název produktu</label>
            <input type="text" id="productName" placeholder="Zadejte název produktu" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
        </div>

        <!-- Main Grid Container -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">

            <!-- First Column: Cost Inputs -->
            <div class="space-y-4">
                <!-- Náklady na filament -->
                <div class="bg-purple-50 p-4 rounded-xl border border-purple-200">
                    <h3 class="text-lg font-bold text-purple-800 mb-3">Náklady na filament</h3>
                    <div class="space-y-4">
                        <div>
                            <label for="filamentTypeDropdown" class="block text-sm font-semibold text-gray-700 mb-1">Typ filamentu</label>
                            <select id="filamentTypeDropdown" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                                <option value="" disabled>-- Vyberte typ --</option>
                                <option value="15">Levné PLA (15 Kč/kg)</option>
                                <option value="20" selected>Běžné PLA (20 Kč/kg)</option>
                                <option value="25">Hedvábné PLA (25 Kč/kg)</option>
                                <option value="30">Dřevěné PLA (30 Kč/kg)</option>
                                <option value="custom">Vlastní</option>
                            </select>
                        </div>
                        <div>
                            <label for="filamentPrice" class="block text-sm font-semibold text-gray-700 mb-1">Cena cívky filamentu (Kč)</label>
                            <input type="number" id="filamentPrice" value="20.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="printWeight" class="block text-sm font-semibold text-gray-700 mb-1">Spotřebovaný filament (gramy)</label>
                            <input type="number" id="printWeight" value="50" min="0" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="printTime" class="block text-sm font-semibold text-gray-700 mb-1">Doba tisku (hodiny)</label>
                            <input type="number" id="printTime" value="2.5" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                    </div>
                </div>
                
                <!-- Režijní náklady -->
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                    <h3 class="text-lg font-bold text-gray-800 mb-3">Režijní náklady</h3>
                    <div class="space-y-4">
                        <div>
                            <label for="electricityCost" class="block text-sm font-semibold text-gray-700 mb-1">Cena elektřiny za kWh (Kč)</label>
                            <input type="number" id="electricityCost" value="0.19" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="printerWattage" class="block text-sm font-semibold text-gray-700 mb-1">Příkon tiskárny (W)</label>
                            <input type="number" id="printerWattage" value="150" min="0" step="1" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="printerAmortization" class="block text-sm font-semibold text-gray-700 mb-1">Amortizace tiskárny (Kč/hodina)</label>
                            <input type="number" id="printerAmortization" value="0.15" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="otherOverhead" class="block text-sm font-semibold text-gray-700 mb-1">Další měsíční režijní náklady (Kč)</label>
                            <p class="text-xs text-gray-500 mb-2">Vyplňte pouze v případě, že chcete zahrnout náklad a rozdělit jej číslem níže. Možná chcete započítat komerční licenci za 30 Kč měsíčně a níže ji vydělit 30 nebo něco podobného. Podivné pole, já vím, ale může být užitečné.</p>
                            <input type="number" id="otherOverhead" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="unitsPerMonth" class="block text-sm font-semibold text-gray-700 mb-1">Dělící faktor pro další měsíční režijní náklady</label>
                            <input type="number" id="unitsPerMonth" value="0" min="0" step="1" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                    </div>
                </div>

                <!-- Další přímé náklady -->
                <div class="bg-gray-50 p-4 rounded-xl border border-gray-200">
                    <h3 class="text-lg font-bold text-gray-800 mb-3">Další přímé náklady</h3>
                    <div class="space-y-4">
                        <div>
                            <label for="cost1" class="block text-sm font-semibold text-gray-700 mb-1">Dodatečný náklad 1 (Kč)</label>
                            <input type="number" id="cost1" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                        <div>
                            <label for="cost2" class="block text-sm font-semibold text-gray-700 mb-1">Dodatečný náklad 2 (Kč)</label>
                            <input type="number" id="cost2" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Second Column: Price & Main Results -->
            <div class="space-y-4">
                <!-- Shipping and Fees Dropdowns -->
                <div class="bg-purple-50 p-4 rounded-xl border border-purple-200 space-y-4">
                    <h3 class="text-lg font-bold text-purple-800 mb-3">Poštovné a poplatky marketplace</h3>
                    <div>
                        <label for="shippingDropdown" class="block text-sm font-semibold text-gray-700 mb-1">Typ nákladů na dopravu</label>
                        <select id="shippingDropdown" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                            <option value="0" selected>Doprava zdarma (0 Kč)</option>
                            <option value="5">Malé poštovné (5 Kč)</option>
                            <option value="7.5">Střední poštovné (7,50 Kč)</option>
                            <option value="11">Velké poštovné (11 Kč)</option>
                            <option value="custom">Vlastní</option>
                        </select>
                    </div>
                    <div>
                        <label for="shippingCost" class="block text-sm font-semibold text-gray-700 mb-1">Náklady na dopravu (Kč)</label>
                        <input type="number" id="shippingCost" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                    <div>
                        <label for="feesDropdown" class="block text-sm font-semibold text-gray-700 mb-1">Typ poplatku marketplace</label>
                        <select id="feesDropdown" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                            <option value="0" selected>IRL - 0 %</option>
                            <option value="0.095">Etsy (bez reklam) - 9,5 %</option>
                            <option value="0.215">Etsy (reklamy) - 21,5 %</option>
                            <option value="0.13">eBay (bez reklam) - 13 %</option>
                            <option value="0.23">eBay (reklamy) - 23 %</option>
                            <option value="0.10">FB - 10 %</option>
                            <option value="0.106">TTS - 10,6 %</option>
                            <option value="custom">Vlastní</option>
                        </select>
                    </div>
                    <div>
                        <label for="feesInput" class="block text-sm font-semibold text-gray-700 mb-1">Poplatek marketplace (%)</label>
                        <input type="number" id="feesInput" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                </div>
                
                <!-- Vstupy pro cenu -->
                <div class="bg-blue-50 p-4 rounded-xl border border-blue-200 space-y-4">
                    <h3 class="text-lg font-bold text-blue-800 mb-3">Vstupy pro cenu</h3>
                    <div>
                        <label for="salePrice" class="block text-sm font-semibold text-gray-700 mb-2">Konečná prodejní cena (Kč)</label>
                        <input type="number" id="salePrice" value="20.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                    <div>
                        <label for="targetProfit" class="block text-sm font-semibold text-gray-700 mb-2">Cílový zisk na prodej (Kč)</label>
                        <input type="number" id="targetProfit" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                    <div>
                        <label for="targetPPH" class="block text-sm font-semibold text-gray-700 mb-2">Cílové PPH (Kč)</label>
                        <input type="number" id="targetPPH" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                    <div>
                        <label for="targetMargin" class="block text-sm font-semibold text-gray-700 mb-2">Cílová marže (%)</label>
                        <input type="number" id="targetMargin" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                </div>
                
                <!-- Doporučené ceny -->
                <div class="bg-yellow-50 p-4 rounded-xl border border-yellow-200">
                    <h3 class="text-lg font-bold text-yellow-800 mb-3 underline">Doporučené ceny</h3>
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Trojnásobné základní COGS (+ doprava a poplatky)</span>
                            <span id="suggestedPrice1" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Cíl 1 Kč PPH</span>
                            <span id="suggestedPrice2" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Cílová MSRP pro zisk na prodej (Kč)</span>
                            <span id="targetProfitPrice" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Cílová MSRP pro cílové PPH (Kč)</span>
                            <span id="targetPPHPrice" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Cílová MSRP pro cílovou marži (Kč)</span>
                            <span id="targetMarginPrice" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Third Column: Rozpis nákladů & Profit -->
            <div class="space-y-4">
                <!-- Rozpis nákladů (Intermediate) -->
                <div class="bg-green-50 p-4 rounded-xl border border-green-200">
                    <h3 class="text-lg font-bold text-green-800 mb-3">Rozpis nákladů</h3>
                    <div class="space-y-4 text-sm">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Materiálové náklady (filament)</span>
                            <span id="materialCost" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Náklady na elektřinu</span>
                            <span id="electricityTotal" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Náklady na amortizaci</span>
                            <span id="amortizationTotal" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Přidělená měsíční režie</span>
                            <span id="overheadAllocated" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Dodatečný náklad 1</span>
                            <span id="cost1Total" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700">Dodatečný náklad 2</span>
                            <span id="cost2Total" class="font-bold text-gray-900">0,00 Kč</span>
                        </div>
                        <div class="border-t border-green-200 pt-4 mt-4 flex justify-between items-center">
                            <span class="text-base font-bold text-green-800">COGS (bez dopravy a poplatků)</span>
                            <span id="baseCOGS" class="text-base font-extrabold text-green-800">0,00 Kč</span>
                        </div>
                    </div>
                </div>
                
                <!-- Final Results -->
                <div id="finalResultsBox" class="p-6 rounded-xl border-4">
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-base font-bold text-gray-800">Celkové COGS</span>
                        <span id="totalCOGS" class="text-base font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="flex justify-between items-center mt-4">
                        <span class="text-sm font-semibold text-gray-700">Náklady na dopravu</span>
                        <span id="shippingCostSouhrn" class="font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="flex justify-between items-center mb-4">
                        <span class="text-sm font-semibold text-gray-700">Poplatek marketplace</span>
                        <span id="marketplaceFeeSouhrn" class="font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="border-t border-gray-200 pt-4 flex justify-between items-center mb-2">
                        <span class="text-base font-bold text-gray-800">Váš zisk na kus</span>
                        <span id="profit" class="text-base font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-base font-bold text-gray-800">Zisková marže</span>
                        <span id="profitMargin" class="text-base font-semibold text-gray-900">0,00%</span>
                    </div>
                     <div class="flex justify-between items-center">
                        <span class="text-base font-bold text-gray-800">Zisk za hodinu (PPH)</span>
                        <span id="pph" class="text-base font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                </div>

                <!-- Discounted Results Box -->
                <div id="discountedResultsBox" class="p-6 rounded-xl border-4">
                    <h3 class="text-xl font-bold text-gray-800 mb-4">Výpočet zisku se slevou</h3>
                    <div class="mb-4">
                        <label for="discountPercent" class="block text-sm font-semibold text-gray-700 mb-2">Sleva %</label>
                        <input type="number" id="discountPercent" value="0.00" min="0" step="0.01" class="w-full md:w-3/4 px-4 py-2 bg-white border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 transition duration-200">
                    </div>
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-base font-semibold text-gray-700">Zlevněná prodejní cena (Kč)</span>
                        <span id="discountedSalePrice" class="font-bold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="border-t border-gray-200 pt-4 flex justify-between items-center mb-2">
                        <span class="text-base font-bold text-gray-800">Váš zisk na kus (se slevou)</span>
                        <span id="discountedProfit" class="text-base font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                    <div class="flex justify-between items-center">
                        <span class="text-base font-bold text-gray-800">Zisková marže (se slevou)</span>
                        <span id="discountedProfitMargin" class="text-base font-semibold text-gray-900">0,00%</span>
                    </div>
                     <div class="flex justify-between items-center">
                        <span class="text-base font-bold text-gray-800">Zisk za hodinu (PPH) (se slevou)</span>
                        <span id="discountedPPH" class="text-base font-semibold text-gray-900">0,00 Kč</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Souhrn Table -->
        <div class="mt-8 pt-8 border-t border-gray-300">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Souhrn</h2>
            <div class="flex flex-col sm:flex-row sm:justify-between sm:items-center mb-4 space-y-2 sm:space-y-0">
                <p class="text-sm text-gray-600">Rychlý přehled aktuálního výpočtu.</p>
                <div class="flex space-x-2">
                    <button id="copySouhrnButton" class="px-4 py-2 bg-blue-600 text-white rounded-lg shadow-md hover:bg-blue-700 transition duration-200">
                        Zkopírovat vše do schránky
                    </button>
                    <button id="copySouhrnRowButton" class="px-4 py-2 bg-blue-600 text-white rounded-lg shadow-md hover:bg-blue-700 transition duration-200">
                        Zkopírovat řádek do schránky
                    </button>
                </div>
            </div>
            <div class="overflow-x-auto rounded-lg shadow-md">
                <table class="w-full text-sm text-left text-gray-600" id="summaryTable">
                    <thead class="text-xs text-gray-700 uppercase bg-gray-50">
                        <tr>
                            <th scope="col" class="px-6 py-3">Název produktu</th>
                            <th scope="col" class="px-6 py-3 text-center">Spotřebovaný filament (g)</th>
                            <th scope="col" class="px-6 py-3 text-center">Doba tisku (h)</th>
                            <th scope="col" class="px-6 py-3 text-center">Náklady na dopravu (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Tržiště</th>
                            <th scope="col" class="px-6 py-3 text-center">Poplatek (%)</th>
                            <th scope="col" class="px-6 py-3 text-center">Základní COGS (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Prodejní cena (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Zisk (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Zisková marže</th>
                            <th scope="col" class="px-6 py-3 text-center">PPH (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Cíl 1 Kč PPH (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Cíl zisku (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Cílové PPH (Kč)</th>
                            <th scope="col" class="px-6 py-3 text-center">Cílová marže (%)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="bg-white border-b">
                            <td class="px-6 py-4 font-medium text-gray-900 whitespace-nowrap" id="summaryProductName"></td>
                            <td class="px-6 py-4 text-center" id="summaryPrintWeight"></td>
                            <td class="px-6 py-4 text-center" id="summaryPrintTime"></td>
                            <td class="px-6 py-4 text-center" id="summaryShippingCost"></td>
                            <td class="px-6 py-4 text-center" id="summaryMarketplaceName"></td>
                            <td class="px-6 py-4 text-center" id="summaryFeePercentage"></td>
                            <td class="px-6 py-4 text-center" id="summaryBaseCOGS"></td>
                            <td class="px-6 py-4 text-center" id="summarySalePrice"></td>
                            <td class="px-6 py-4 text-center" id="summaryProfit"></td>
                            <td class="px-6 py-4 text-center" id="summaryProfitMargin"></td>
                            <td class="px-6 py-4 text-center" id="summaryPPH"></td>
                            <td class="px-6 py-4 text-center" id="summaryTargetPrice1"></td>
                            <td class="px-6 py-4 text-center" id="summaryTargetPrice2"></td>
                            <td class="px-6 py-4 text-center" id="summaryTargetPPHPrice"></td>
                            <td class="px-6 py-4 text-center" id="summaryTargetMarginPrice"></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Footnote Section for Formulas -->
        <div class="mt-8 pt-8 border-t border-gray-300">
            <h2 class="text-2xl font-bold text-gray-800 mb-4">Výpočetní vzorce</h2>
            <div class="max-w-none text-sm text-gray-600">
                <p>Výpočty vycházejí z následujících vzorců:</p>

                <h3 class="text-lg font-bold text-gray-700 mt-6">Náklady na prodané zboží (COGS)</h3>

                <p><strong>Materiálové náklady:</strong></p>
                <p>Materiálové náklady = (Cena cívky filamentu / 1000) * Spotřebovaný filament (gramy)</p>

                <p><strong>Náklady na elektřinu:</strong></p>
                <p>Náklady na elektřinu = (Příkon tiskárny * Doba tisku / 1000) * Cena elektřiny za kWh</p>

                <p><strong>Náklady na amortizaci:</strong></p>
                <p>Náklady na amortizaci = Amortizace tiskárny (za hodinu) * Doba tisku</p>

                <p><strong>Přidělená měsíční režie:</strong></p>
                <p>Přidělená měsíční režie = Další měsíční režijní náklady / Dělící faktor pro další měsíční režijní náklady</p>
                <p class="text-xs italic">(Tento náklad je 0 Kč, pokud je dělící faktor 0)</p>

                <p><strong>Dodatečný náklad 1:</strong></p>
                <p>Dodatečný náklad 1 = Hodnota z pole Náklad 1</p>

                <p><strong>Dodatečný náklad 2:</strong></p>
                <p>Dodatečný náklad 2 = Hodnota z pole Náklad 2</p>

                <p><strong>Poplatek marketplace:</strong></p>
                <p>Poplatek marketplace = Konečná prodejní cena * Poplatek marketplace (%)</p>

                <p><strong>Základní COGS (bez dopravy a poplatků):</strong></p>
                <p>Základní COGS = Materiálové náklady + Dodatečný náklad 1 + Dodatečný náklad 2 + Náklady na elektřinu + Náklady na amortizaci + Přidělená měsíční režie</p>

                <p><strong>Celkové COGS:</strong></p>
                <p>Celkové COGS = Základní COGS + Náklady na dopravu + Poplatek marketplace</p>

                <h3 class="text-lg font-bold text-gray-700 mt-6">Zisk a doporučené ceny</h3>

                <p><strong>Váš zisk na kus:</strong></p>
                <p>Zisk = Konečná prodejní cena - Celkové COGS</p>

                <p><strong>Zisková marže:</strong></p>
                <p>Zisková marže = (Zisk / Konečná prodejní cena) * 100</p>

                <p><strong>Zisk za hodinu (PPH):</strong></p>
                <p>PPH = Zisk / Doba tisku</p>

                <p class="text-xs italic">(Tento náklad je 0 Kč, pokud je doba tisku 0)</p>
                <p><strong>Doporučená cena (3× základní COGS):</strong></p>
                <p>Doporučená cena = ((Základní COGS * 3) + Náklady na dopravu) / (1 - Poplatek marketplace (%))</p>

                <p><strong>Doporučená cena (cíl 1 Kč PPH):</strong></p>
                <p>Doporučená cena = (Základní COGS + Náklady na dopravu + Doba tisku) / (1 - Poplatek marketplace (%))</p>

                <p><strong>Doporučená cena (cílový zisk v Kč na prodej):</strong></p>
                <p>Doporučená cena = (Základní COGS + Náklady na dopravu + Cílový zisk na prodej) / (1 - Poplatek marketplace (%))</p>

                <p><strong>Doporučená cena (cílové PPH):</strong></p>
                <p>Doporučená cena = (Základní COGS + Náklady na dopravu + (Cílové PPH * Doba tisku)) / (1 - Poplatek marketplace (%))</p>

                <p><strong>Doporučená cena (cílová marže):</strong></p>
                <p>Doporučená cena = (Základní COGS + Náklady na dopravu) / (1 - (Poplatek marketplace (%) + Cílová marže (%)))</p>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const inputs = document.querySelectorAll('input');
            const dropdowns = document.querySelectorAll('select');
            const outputs = {
                materialCost: document.getElementById('materialCost'),
                cost1Total: document.getElementById('cost1Total'),
                cost2Total: document.getElementById('cost2Total'),
                electricityTotal: document.getElementById('electricityTotal'),
                amortizationTotal: document.getElementById('amortizationTotal'),
                overheadAllocated: document.getElementById('overheadAllocated'),
                baseCOGS: document.getElementById('baseCOGS'),
                shippingCostSouhrn: document.getElementById('shippingCostSouhrn'),
                marketplaceFeeSouhrn: document.getElementById('marketplaceFeeSouhrn'),
                totalCOGS: document.getElementById('totalCOGS'),
                profit: document.getElementById('profit'),
                profitMargin: document.getElementById('profitMargin'),
                pph: document.getElementById('pph'),
                suggestedPrice1: document.getElementById('suggestedPrice1'),
                suggestedPrice2: document.getElementById('suggestedPrice2'),
                targetProfitPrice: document.getElementById('targetProfitPrice'),
                targetPPHPrice: document.getElementById('targetPPHPrice'),
                // New output element for the target margin price
                targetMarginPrice: document.getElementById('targetMarginPrice'),
                finalResultsBox: document.getElementById('finalResultsBox'),
                
                // Discounted outputs
                discountedResultsBox: document.getElementById('discountedResultsBox'),
                discountedSalePrice: document.getElementById('discountedSalePrice'),
                discountedProfit: document.getElementById('discountedProfit'),
                discountedProfitMargin: document.getElementById('discountedProfitMargin'),
                discountedPPH: document.getElementById('discountedPPH'),

                // Souhrn Table outputs
                summaryProductName: document.getElementById('summaryProductName'),
                summaryPrintWeight: document.getElementById('summaryPrintWeight'),
                summaryPrintTime: document.getElementById('summaryPrintTime'),
                summaryShippingCost: document.getElementById('summaryShippingCost'),
                summaryMarketplaceName: document.getElementById('summaryMarketplaceName'),
                summaryFeePercentage: document.getElementById('summaryFeePercentage'),
                summaryBaseCOGS: document.getElementById('summaryBaseCOGS'),
                summarySalePrice: document.getElementById('summarySalePrice'),
                summaryProfit: document.getElementById('summaryProfit'),
                summaryProfitMargin: document.getElementById('summaryProfitMargin'),
                summaryPPH: document.getElementById('summaryPPH'),
                summaryTargetPrice1: document.getElementById('summaryTargetPrice1'),
                summaryTargetPrice2: document.getElementById('summaryTargetPrice2'),
                summaryTargetPPHPrice: document.getElementById('summaryTargetPPHPrice'),
                // New summary table cell for target margin price
                summaryTargetMarginPrice: document.getElementById('summaryTargetMarginPrice'),
            };

            const currencyFormatter = new Intl.NumberFormat('cs-CZ', {
                style: 'currency',
                currency: 'CZK'
            });
            const formatCurrency = (value) => currencyFormatter.format(Number.isFinite(value) ? value : 0);
            const formatPercentage = (value) => {
                const numericValue = Number.isFinite(value) ? value : 0;
                return `${numericValue.toLocaleString('cs-CZ', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                })}%`;
            };

            const filamentTypeDropdown = document.getElementById('filamentTypeDropdown');
            const filamentPriceInput = document.getElementById('filamentPrice');
            const shippingDropdown = document.getElementById('shippingDropdown');
            const shippingCostInput = document.getElementById('shippingCost');
            const feesDropdown = document.getElementById('feesDropdown');
            const feesInput = document.getElementById('feesInput');
            const filamentSpoolWeight = 1000; // Grams

            // Initial filament price setting based on dropdown value
            if (filamentTypeDropdown.value) {
                const selectedPricePerKg = parseFloat(filamentTypeDropdown.value);
                filamentPriceInput.value = (selectedPricePerKg).toFixed(2);
            }
            
            // Initial shipping cost setting based on dropdown value
            if (shippingDropdown.value) {
                const selectedShippingCost = parseFloat(shippingDropdown.value);
                shippingCostInput.value = (selectedShippingCost).toFixed(2);
            }

            // Initial marketplace fees setting based on dropdown value
            if (feesDropdown.value) {
                const selectedFee = parseFloat(feesDropdown.value);
                feesInput.value = (selectedFee * 100).toFixed(2);
            }

            function updateCalculator() {
                // Get all input and dropdown values
                const productName = document.getElementById('productName').value || 'Neuvedeno';
                const salePrice = parseFloat(document.getElementById('salePrice').value) || 0;
                const filamentPrice = parseFloat(document.getElementById('filamentPrice').value) || 0;
                const shippingCost = parseFloat(document.getElementById('shippingCost').value) || 0;
                const printWeight = parseFloat(document.getElementById('printWeight').value) || 0;
                const printTime = parseFloat(document.getElementById('printTime').value) || 0;
                const cost1 = parseFloat(document.getElementById('cost1').value) || 0;
                const cost2 = parseFloat(document.getElementById('cost2').value) || 0;
                const electricityCost = parseFloat(document.getElementById('electricityCost').value) || 0;
                const printerWattage = parseFloat(document.getElementById('printerWattage').value) || 0;
                const printerAmortization = parseFloat(document.getElementById('printerAmortization').value) || 0;
                const otherOverhead = parseFloat(document.getElementById('otherOverhead').value) || 0;
                const unitsPerMonth = parseFloat(document.getElementById('unitsPerMonth').value) || 0;
                
                const feesDropdown = document.getElementById('feesDropdown');
                const feePercentage = (parseFloat(document.getElementById('feesInput').value) || 0) / 100;
                const marketplaceName = feesDropdown.options[feesDropdown.selectedIndex].text;
                
                // Get discount percentage
                const discountPercent = parseFloat(document.getElementById('discountPercent').value) || 0;
                
                // Get target profit
                const targetProfit = parseFloat(document.getElementById('targetProfit').value) || 0;
                
                // Get target PPH (new input)
                const targetPPH = parseFloat(document.getElementById('targetPPH').value) || 0;

                // Get target margin (new input)
                const targetMargin = (parseFloat(document.getElementById('targetMargin').value) || 0) / 100;


                // --- Base COGS Calculation (excl. Shipping & Fees) ---
                // Přímé materiálové náklady (filament)
                const costPerGram = filamentPrice / filamentSpoolWeight;
                const materialCost = costPerGram * printWeight;

                // Náklady na elektřinu
                const printerkWh = (printerWattage * printTime) / 1000;
                const electricityTotal = printerkWh * electricityCost;
                
                // Náklady na amortizaci
                const amortizationTotal = printerAmortization * printTime;

                // Allocated Overhead
                const overheadAllocated = (unitsPerMonth > 0) ? otherOverhead / unitsPerMonth : 0;

                // Calculate Base COGS
                const baseCOGS = materialCost + cost1 + cost2 + electricityTotal + amortizationTotal + overheadAllocated;


                // --- Final COGS and Profit Calculation (incl. Shipping & Fees) ---
                // Total Fees (calculated from the sale price)
                const totalFees = salePrice * feePercentage;
                const totalCOGS = baseCOGS + shippingCost + totalFees;

                // Profit
                const profit = salePrice - totalCOGS;
                
                // Zisková marže
                const profitMargin = (salePrice > 0) ? (profit / salePrice) * 100 : 0;

                // Total time for PPH calculation (only print time)
                const totalWorkHours = printTime;

                // Zisk za hodinu (PPH) - based on total time
                const pph = (totalWorkHours > 0) ? profit / totalWorkHours : 0;
                
                // --- Výpočet zisku se slevou ---
                const discountedSalePrice = salePrice * (1 - discountPercent / 100);
                const discountedTotalFees = discountedSalePrice * feePercentage;
                const discountedTotalCOGS = baseCOGS + shippingCost + discountedTotalFees;
                const discountedProfit = discountedSalePrice - discountedTotalCOGS;
                const discountedProfitMargin = (discountedSalePrice > 0) ? (discountedProfit / discountedSalePrice) * 100 : 0;
                const discountedPPH = (totalWorkHours > 0) ? discountedProfit / totalWorkHours : 0;


                // --- Doporučené ceny ---
                let suggestedPrice1 = 0;
                let suggestedPrice2 = 0;
                let targetProfitPrice = 0;
                let targetPPHPrice = 0;
                let targetMarginPrice = 0; // New variable for the target margin price

                if (1 - feePercentage > 0) {
                     suggestedPrice1 = ((baseCOGS * 3) + shippingCost) / (1 - feePercentage);
                     suggestedPrice2 = (baseCOGS + shippingCost + totalWorkHours) / (1 - feePercentage);
                     targetProfitPrice = (baseCOGS + shippingCost + targetProfit) / (1 - feePercentage);
                     targetPPHPrice = (baseCOGS + shippingCost + (targetPPH * totalWorkHours)) / (1 - feePercentage);

                     // Calculate the new target margin price
                     const denominator = 1 - (feePercentage + targetMargin);
                     if (denominator > 0) {
                        targetMarginPrice = (baseCOGS + shippingCost) / denominator;
                     }
                }


                // Display results
                outputs.materialCost.textContent = formatCurrency(materialCost);
                outputs.electricityTotal.textContent = formatCurrency(electricityTotal);
                outputs.amortizationTotal.textContent = formatCurrency(amortizationTotal);
                outputs.overheadAllocated.textContent = formatCurrency(overheadAllocated);
                outputs.cost1Total.textContent = formatCurrency(cost1);
                outputs.cost2Total.textContent = formatCurrency(cost2);
                outputs.baseCOGS.textContent = formatCurrency(baseCOGS);

                // Display shipping and fees in the summary section
                outputs.shippingCostSouhrn.textContent = formatCurrency(shippingCost);
                outputs.marketplaceFeeSouhrn.textContent = formatCurrency(totalFees);

                outputs.totalCOGS.textContent = formatCurrency(totalCOGS);
                outputs.profit.textContent = formatCurrency(profit);
                outputs.profitMargin.textContent = formatPercentage(profitMargin);
                outputs.pph.textContent = formatCurrency(pph);

                outputs.suggestedPrice1.textContent = formatCurrency(suggestedPrice1);
                outputs.suggestedPrice2.textContent = formatCurrency(suggestedPrice2);
                outputs.targetProfitPrice.textContent = formatCurrency(targetProfitPrice);
                outputs.targetPPHPrice.textContent = formatCurrency(targetPPHPrice);
                outputs.targetMarginPrice.textContent = formatCurrency(targetMarginPrice); // Display the new price

                // Change color of final results box based on profit
                if (profit > 0) {
                    outputs.finalResultsBox.classList.remove('profit-box-negative');
                    outputs.finalResultsBox.classList.add('profit-box-positive');
                } else {
                    outputs.finalResultsBox.classList.remove('profit-box-positive');
                    outputs.finalResultsBox.classList.add('profit-box-negative');
                }
                
                // Display discounted results
                outputs.discountedSalePrice.textContent = formatCurrency(discountedSalePrice);
                outputs.discountedProfit.textContent = formatCurrency(discountedProfit);
                outputs.discountedProfitMargin.textContent = formatPercentage(discountedProfitMargin);
                outputs.discountedPPH.textContent = formatCurrency(discountedPPH);

                // Change color of discounted results box based on profit
                if (discountedProfit > 0) {
                    outputs.discountedResultsBox.classList.remove('profit-box-negative');
                    outputs.discountedResultsBox.classList.add('profit-box-positive');
                } else {
                    outputs.discountedResultsBox.classList.remove('profit-box-positive');
                    outputs.discountedResultsBox.classList.add('profit-box-negative');
                }


                // Update summary table
                outputs.summaryProductName.textContent = productName;
                outputs.summaryPrintWeight.textContent = printWeight;
                outputs.summaryPrintTime.textContent = printTime;
                outputs.summaryShippingCost.textContent = formatCurrency(shippingCost);
                outputs.summaryMarketplaceName.textContent = marketplaceName;
                outputs.summaryFeePercentage.textContent = formatPercentage(feePercentage * 100);
                outputs.summaryBaseCOGS.textContent = formatCurrency(baseCOGS);
                outputs.summarySalePrice.textContent = formatCurrency(salePrice);
                outputs.summaryProfit.textContent = formatCurrency(profit);
                outputs.summaryProfitMargin.textContent = formatPercentage(profitMargin);
                outputs.summaryPPH.textContent = formatCurrency(pph);
                outputs.summaryTargetPrice1.textContent = formatCurrency(suggestedPrice2);
                outputs.summaryTargetPrice2.textContent = formatCurrency(targetProfitPrice);
                outputs.summaryTargetPPHPrice.textContent = formatCurrency(targetPPHPrice);
                outputs.summaryTargetMarginPrice.textContent = formatCurrency(targetMarginPrice); // Update the new summary table cell
            }
            
            // Handle Filament Type dropdown change
            filamentTypeDropdown.addEventListener('change', (e) => {
                if (e.target.value === 'custom') {
                    filamentPriceInput.value = '';
                    filamentPriceInput.placeholder = 'Zadejte vlastní cenu';
                    filamentPriceInput.focus();
                } else {
                    const selectedPricePerKg = parseFloat(e.target.value);
                    filamentPriceInput.value = (selectedPricePerKg).toFixed(2);
                }
                updateCalculator();
            });

            // Handle Shipping Cost dropdown change
            shippingDropdown.addEventListener('change', (e) => {
                if (e.target.value === 'custom') {
                    shippingCostInput.value = '';
                    shippingCostInput.placeholder = 'Zadejte vlastní cenu';
                    shippingCostInput.focus();
                } else {
                    const selectedShippingCost = parseFloat(e.target.value);
                    shippingCostInput.value = (selectedShippingCost).toFixed(2);
                }
                updateCalculator();
            });

            // Handle Fees dropdown change
            feesDropdown.addEventListener('change', (e) => {
                if (e.target.value === 'custom') {
                    feesInput.value = '';
                    feesInput.placeholder = 'Zadejte vlastní poplatek (%)';
                    feesInput.focus();
                } else {
                    const selectedFee = parseFloat(e.target.value);
                    feesInput.value = (selectedFee * 100).toFixed(2);
                }
                updateCalculator();
            });

            // Copy to clipboard functionality for the entire table
            document.getElementById('copySouhrnButton').addEventListener('click', () => {
                const table = document.getElementById('summaryTable');
                let tableText = '';
                
                // Get headers
                const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.textContent.trim());
                tableText += headers.join('\t') + '\n';
                
                // Get row data
                const row = table.querySelector('tbody tr');
                const rowData = Array.from(row.querySelectorAll('td')).map(td => td.textContent.trim());
                tableText += rowData.join('\t');

                // Create a temporary textarea to hold the text
                const tempTextArea = document.createElement('textarea');
                tempTextArea.value = tableText;
                document.body.appendChild(tempTextArea);
                tempTextArea.select();
                document.execCommand('copy');
                document.body.removeChild(tempTextArea);

                // Simple feedback for the user
                const originalText = document.getElementById('copySouhrnButton').textContent;
                document.getElementById('copySouhrnButton').textContent = 'Zkopírováno!';
                setTimeout(() => {
                    document.getElementById('copySouhrnButton').textContent = originalText;
                }, 2000);
            });
            
            // Copy to clipboard functionality for the data row only
            document.getElementById('copySouhrnRowButton').addEventListener('click', () => {
                const table = document.getElementById('summaryTable');
                let rowText = '';
                
                // Get row data
                const row = table.querySelector('tbody tr');
                const rowData = Array.from(row.querySelectorAll('td')).map(td => td.textContent.trim());
                rowText += rowData.join('\t');

                // Create a temporary textarea to hold the text
                const tempTextArea = document.createElement('textarea');
                tempTextArea.value = rowText;
                document.body.appendChild(tempTextArea);
                tempTextArea.select();
                document.execCommand('copy');
                document.body.removeChild(tempTextArea);

                // Simple feedback for the user
                const originalText = document.getElementById('copySouhrnRowButton').textContent;
                document.getElementById('copySouhrnRowButton').textContent = 'Zkopírováno!';
                setTimeout(() => {
                    document.getElementById('copySouhrnRowButton').textContent = originalText;
                }, 2000);
            });


            // Recalculate on any input or dropdown change
            inputs.forEach(input => input.addEventListener('input', updateCalculator));
            dropdowns.forEach(dropdown => dropdown.addEventListener('change', updateCalculator));

            // Initial calculation
            updateCalculator();
        });
    </script>
</body>
</html>
